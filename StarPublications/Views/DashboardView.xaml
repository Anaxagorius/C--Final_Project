<UserControl x:Class="StarPublications.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </UserControl.InputBindings>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="4,0,4,16">

            <!-- ── Welcome Banner ──────────────────────────────────────────── -->
            <Border Style="{StaticResource WelcomeBannerStyle}" Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E1B4B" Offset="0"/>
                        <GradientStop Color="#4338CA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Welcome back! 👋"
                                   FontSize="26" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Here's what's happening in your publications right now."
                                   FontSize="14" Foreground="#C7D2FE"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="  Refreshing…"
                                   Style="{StaticResource LoadingTextStyle}"
                                   Foreground="#C7D2FE"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Content="🔄  Refresh"
                                Foreground="White"
                                BorderBrush="White"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Reload dashboard data (F5)"
                                Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Stat Cards ───────────────────────────────────────────────── -->
            <UniformGrid Columns="5" Margin="0,0,0,20">

                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="📚" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalBooks}" Style="{StaticResource StatNumberStyle}"/>
                        <TextBlock Text="BOOKS" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Margin="3,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#10B981"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="✍️" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalAuthors}" Style="{StaticResource StatNumberStyle}">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#059669"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="AUTHORS" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Margin="3,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#F59E0B"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="🏢" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalPublishers}" Style="{StaticResource StatNumberStyle}">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#D97706"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="PUBLISHERS" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Margin="3,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#6366F1"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="🏪" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalStores}" Style="{StaticResource StatNumberStyle}">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#4F46E5"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="STORES" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Margin="6,0,0,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#EF4444"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock Text="🛒" FontSize="30" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalOrders}" Style="{StaticResource StatNumberStyle}">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="#DC2626"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="ORDERS" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- ── Bottom Panels ────────────────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Orders -->
                <Border Grid.Column="0" Style="{StaticResource CardPanelStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="🕐  Recent Orders"
                                   Style="{StaticResource SubHeadingStyle}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding RecentOrders}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   LineHeight="24"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Top Books by Sales -->
                <Border Grid.Column="1" Style="{StaticResource CardPanelStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="🏆  Top Books by Sales"
                                   Style="{StaticResource SubHeadingStyle}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="{Binding TopBooks}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   LineHeight="24"
                                   FontSize="13"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Error -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorTextStyle}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                       Margin="0,14,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
