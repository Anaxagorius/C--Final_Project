<UserControl x:Class="StarPublications.Views.PublisherSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page heading -->
        <TextBlock Grid.Row="0" Text="Publisher Search and Display"
                   Style="{StaticResource HeadingStyle}"
                   Margin="0,0,0,12"/>

        <!-- Search panel -->
        <Border Grid.Row="1" Style="{StaticResource CardPanelStyle}" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Name:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                <TextBox Width="160" Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,16,0"/>

                <TextBlock Text="City:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                <TextBox Width="120" Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SearchCity, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,16,0"/>

                <TextBlock Text="State:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                <TextBox Width="60" Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SearchState, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,16,0"/>

                <TextBlock Text="Country:" Style="{StaticResource LabelStyle}" Margin="0,0,8,0"/>
                <TextBox Width="120" Style="{StaticResource ModernTextBoxStyle}"
                         Text="{Binding SearchCountry, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,16,0"/>

                <Button Content="🔍 Search" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SearchCommand}"/>
                <Button Content="✖ Clear"   Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearCommand}"/>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Publishers grid -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="🏢 Load All" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding LoadAllCommand}"/>
                    <TextBlock Text="  Loading…"
                               Style="{StaticResource LoadingTextStyle}"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          Style="{StaticResource ModernDataGridStyle}"
                          ItemsSource="{Binding Publishers}"
                          SelectedItem="{Binding SelectedPublisher}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Pub ID"   Binding="{Binding PubId}"   Width="70"/>
                        <DataGridTextColumn Header="Name"     Binding="{Binding PubName}"  Width="*"/>
                        <DataGridTextColumn Header="City"     Binding="{Binding City}"     Width="120"/>
                        <DataGridTextColumn Header="State"    Binding="{Binding State}"    Width="60"/>
                        <DataGridTextColumn Header="Country"  Binding="{Binding Country}"  Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Detail panel -->
            <Border Grid.Column="1" Style="{StaticResource CardPanelStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Publisher Details"
                                   Style="{StaticResource SubHeadingStyle}"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Publisher ID:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding SelectedPublisher.PubId}"
                                   FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,2,0,10"/>

                        <TextBlock Text="Name:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding SelectedPublisher.PubName}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,10"/>

                        <TextBlock Text="City:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding SelectedPublisher.City}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,10"/>

                        <TextBlock Text="State:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding SelectedPublisher.State}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,10"/>

                        <TextBlock Text="Country:" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding SelectedPublisher.Country}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,10"/>

                        <Separator Margin="0,4,0,8"/>

                        <TextBlock Text="Published Titles:" Style="{StaticResource SubHeadingStyle}"/>
                        <TextBlock Text="{Binding DetailTitles}"
                                   TextWrapping="Wrap" Margin="0,2,0,10"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12"/>

                        <TextBlock Text="About the Publisher:" Style="{StaticResource SubHeadingStyle}"/>
                        <TextBlock Text="{Binding DetailPrInfo}"
                                   TextWrapping="Wrap" Margin="0,2,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Error message -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorTextStyle}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
    </Grid>
</UserControl>
