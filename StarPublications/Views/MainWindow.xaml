<Window x:Class="StarPublications.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StarPublications.ViewModels"
        xmlns:views="clr-namespace:StarPublications.Views"
        Title="Star Publications — Sales Order Management"
        Height="740" Width="1160"
        MinHeight="620" MinWidth="940"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- DataTemplates map ViewModels to their Views -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesOrderViewModel}">
            <views:SalesOrderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookSearchViewModel}">
            <views:BookSearchView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PublisherSearchViewModel}">
            <views:PublisherSearchView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header / brand bar -->
            <RowDefinition Height="Auto"/>  <!-- Navigation bar -->
            <RowDefinition Height="*"/>     <!-- Content area -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header (gradient) ─────────────────────────────────────────── -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E1B4B" Offset="0"/>
                    <GradientStop Color="#4338CA" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📚" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Star Publications"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Sales Order Management Subsystem"
                                   FontSize="11"
                                   Foreground="#C7D2FE"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="{Binding CurrentTime}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="13" Foreground="#C7D2FE" FontFamily="Consolas"/>
            </Grid>
        </Border>

        <!-- ── Navigation bar ────────────────────────────────────────────── -->
        <Border Grid.Row="1">
            <Border.Background>
                <SolidColorBrush Color="#1E1B4B"/>
            </Border.Background>
            <StackPanel Orientation="Horizontal">

                <!-- Dashboard -->
                <Button Content="🏠  Dashboard"
                        Command="{Binding ShowDashboardCommand}"
                        ToolTip="Home — at-a-glance statistics">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Sales Orders -->
                <Button Content="🛒  Sales Orders"
                        Command="{Binding ShowSalesOrdersCommand}"
                        ToolTip="Add, edit and delete sales orders">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSalesOrdersActive}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Books -->
                <Button Content="📖  Books"
                        Command="{Binding ShowBooksCommand}"
                        ToolTip="Browse and search book titles">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBooksActive}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Publishers -->
                <Button Content="🏢  Publishers"
                        Command="{Binding ShowPublishersCommand}"
                        ToolTip="Browse and search publishers">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPublishersActive}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>
        </Border>

        <!-- ── Content area (ContentControl swaps child views) ───────────── -->
        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentView}"
                        Margin="14"/>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="3"
                Background="#F1F5F9"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="14,5">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Tip: press F5 to refresh · Ctrl+N to add · Ctrl+S to save · Esc to cancel"
                           FontSize="11" FontStyle="Italic"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
